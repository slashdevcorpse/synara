{
  "name": "@synara/desktop",
  "version": "0.5.5",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "bun run scripts/dev.mjs",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "build": "tsdown",
    "start": "bun run scripts/start-electron.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit --project e2e/tsconfig.json",
    "test": "vitest run --maxWorkers=50% --passWithNoTests",
    "test:local-preview-security": "node scripts/local-preview-runtime-security-runner.mjs",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "smoke-test": "node scripts/smoke-test.mjs",
    "persistence-smoke-test": "node scripts/session-persistence-smoke.mjs"
  },
  "dependencies": {
    "effect": "catalog:",
    "electron": "40.10.6",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@synara/contracts": "workspace:*",
    "@synara/shared": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wait-on": "^8.0.2"
  },
  "productName": "Synara"
}
